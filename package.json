{
  "name": "meeting-english-coach",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first tool for reviewing spoken English from meeting recordings with Gemini.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node scripts/static-server.js",
    "start:proxy": "node proxy.js",
    "check": "node --check app.js",
    "test": "npm run test:batch",
    "test:e2e": "playwright test",
    "test:batch": "playwright test tests/batch-mode.spec.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
